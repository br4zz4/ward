# Contributor: br4zz4
# Maintainer: br4zz4
pkgname=ward
pkgver=0.1.47
pkgrel=0
pkgdesc="Hierarchical secrets manager"
url="https://github.com/br4zz4/ward"
arch="all"
license="MIT"
makedepends="go"
source="$pkgname-$pkgver.tar.gz::https://github.com/br4zz4/ward/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/$pkgname-$pkgver"

build() {
	cd "$builddir"
	go build -o ward ./cmd/ward
}

check() {
	cd "$builddir"
	go test ./...
}

package() {
	install -Dm755 "$builddir/ward" "$pkgdir/usr/bin/ward"
	install -Dm644 "$builddir/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
